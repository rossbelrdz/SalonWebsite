{
  "name": "web",
  "version": "0.11.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma generate && prisma db push && tsx prisma/seed.ts && node scripts/assert-prisma-client.mjs",
    "db:reset": "prisma db push --force-reset && SEED_RESET_MATRICES=1 tsx prisma/seed.ts",
    "db:assert": "node scripts/assert-prisma-client.mjs",
    "images:optimize": "node scripts/optimize-salon-images.mjs",
    "worker": "tsx worker/index.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.5",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "maplibre-gl": "^4.7.1",
    "next": "15.5.9",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.17.2",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "prisma": "^6.19.0",
    "tsx": "^4.23.1",
    "typescript": "^5"
  },
  "allowScripts": {
    "@prisma/engines@6.19.0": true,
    "prisma@6.19.0": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "@prisma/client@6.19.0": true,
    "fsevents@2.3.3": true
  }
}
