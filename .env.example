# Copiar a .env (nunca commitear .env)
# Deploy / tunnel: docs/DEPLOY.md
# App Next.js vive en /web

POSTGRES_USER=salon
POSTGRES_PASSWORD=change_me
POSTGRES_DB=salon
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379
REDIS_PORT=6379

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

APP_PORT=3000
APP_ENCRYPTION_KEY=generate_a_long_random_string_at_least_32
SESSION_SECRET=generate_another_long_random_string
TENANT_SLUG=demo

# URL pública de la app (la que ve el browser / tunnel)
# Producción (docker compose por defecto): https://salon.freonx.org
# Dev local (docker-compose.dev.yml): http://localhost:3010
PUBLIC_APP_URL=https://salon.freonx.org
NEXT_PUBLIC_APP_URL=https://salon.freonx.org

# Integraciones de producto (Resend, Telegram, Turnstile) se configuran en
# Admin → Configuración y se guardan cifradas en TenantSettings (AES-GCM).
# No van en .env de la app.

# Cloudflare Tunnel — perfil Compose "tunnel"
# Hostname: salon.freonx.org → http://app:3000
# Token también en docs/credentials.md (gitignored)
CLOUDFLARE_TUNNEL_TOKEN=

# Web Push VAPID (generar: cd web && npx web-push generate-vapid-keys --json)
# NEXT_PUBLIC_* se empaqueta en el build de Next (rebuild app en prod al rotar)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:freonx@freonx.org
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
