# Copiar a .env (nunca commitear .env)
# Deploy / tunnel: docs/DEPLOY.md
# App Next.js vive en /web

POSTGRES_USER=salon
POSTGRES_PASSWORD=change_me
POSTGRES_DB=salon
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379
REDIS_PORT=6379

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

APP_PORT=3000
APP_ENCRYPTION_KEY=generate_a_long_random_string_at_least_32
SESSION_SECRET=generate_another_long_random_string
TENANT_SLUG=demo

# URL pública de la app
# Local: http://localhost:3000
# Deploy (Cloudflare Tunnel): https://salon.freonx.org
PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Integraciones (plataforma o desarrollo)
RESEND_API_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TELEGRAM_BOT_TOKEN=

# Cloudflare Tunnel — perfil Compose "tunnel"
# Hostname: salon.freonx.org → http://app:3000
# Token también en docs/credentials.md (gitignored)
CLOUDFLARE_TUNNEL_TOKEN=

# Web Push VAPID (generar: npx web-push generate-vapid-keys --json)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tu-dominio.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
